# Copy this file to ".env" and fill in real values.
# The real .env is git-ignored and must NOT be pushed to GitHub.

# Server
# Note: macOS uses port 5000 for AirPlay Receiver, so we default to 5001.
PORT=your port
NODE_ENV=your env

# Database
MONGO_URI=your mongo db url

# JWT
JWT_SECRET=make your own secret
JWT_EXPIRES_IN= your expire limet 


# CORS (the URL where the Next.js frontend runs)
# Required for the auth cookie: with credentials enabled the origin can't be "*".
CLIENT_URL=your local host

# Auth cookie SameSite policy: "lax" (default) or "strict" when the frontend
# and backend share a site. Use "none" if they're on different domains
# (e.g. Vercel + Render) — "none" only works over HTTPS (secure cookies).
COOKIE_SAMESITE=lax
